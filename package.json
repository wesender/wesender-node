{
  "name": "@wesender/wesender-node",
  "version": "1.0.0",
  "description": "Officiële Node.js SDK voor de WeSender e-mail API",
  "type": "module",
  "main":  "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types":   "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build":    "tsup src/index.ts --format esm,cjs --dts --clean",
    "test":     "bun test",
    "typecheck": "tsc --noEmit"
  },
  "files": ["dist/", "README.md", "LICENSE"],
  "keywords": ["email", "api", "transactional", "wesender", "nederland", "sdk"],
  "author":   "WeSender <hallo@wesender.nl>",
  "license":  "MIT",
  "repository": {
    "type": "git",
    "url":  "https://github.com/wesender/wesender-node.git"
  },
  "homepage": "https://wesender.nl/docs/sdks/nodejs",
  "bugs":     "https://github.com/wesender/wesender-node/issues",
  "publishConfig": {
    "access":   "public",
    "registry": "https://npm.pkg.github.com"
  },
  "devDependencies": {
    "tsup":       "^8.0.0",
    "typescript": "^5.6.0"
  },
  "engines": { "node": ">=18" }
}
